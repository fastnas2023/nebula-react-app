    "title1": "Dismantling the",
    "title2": "status quo.",
    "desc": "We threw away the expensive streaming farms and rebuilt video conferencing purely for the browser's edge capabilities.",
    "card1": {
      "title": "100% P2P Mesh Network",
      "desc": "The server is just a matchmaker. Once connected, all audio and video streams flow directly between browsers. Unplug the server, and the meeting continues flawlessly."
    },
    "card2": {
      "title": "Burn After Reading",
      "desc": "Media streams are generated, encrypted, and destroyed entirely within client memory. Physical-level data sovereignty."
    },
    "card3": {
      "title": "Canvas Recording",
      "desc": "We use native HTML5 Canvas & AudioContext to composite multi-track layouts locally. Zero cloud recording costs."
    },
